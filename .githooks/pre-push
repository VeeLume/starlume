#!/usr/bin/env bash
set -euo pipefail
# Pre-push: fmt-check + clippy gate (mirrors CI). Bypass once with: git push --no-verify
# Heavy workspaces: delete this hook if per-push clippy is too slow (CI still enforces it).
[ -f Cargo.toml ] || exit 0   # not a Rust project at this root — skip

echo "▶ cargo fmt --check"
cargo fmt --all -- --check

echo "▶ cargo clippy"
cargo clippy --workspace --all-targets -- -D warnings

echo "✓ pre-push checks passed"

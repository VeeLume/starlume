{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Starlume",
  "version": "0.1.0",
  "identifier": "com.veelume.starlume",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1430",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "Starlume",
        "width": 1100,
        "height": 750,
        "visible": false,
        "backgroundColor": "#131316",
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis"
    ],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDlDOTg1MTAwQ0Y2OTZDM0UKUldRK2JHblBBRkdZbkRsa243RlJITlFLM0xEWmhkMjVmS1h3eHIzVFdNVE5zbUF5TEVteXQwZ1EK",
      "endpoints": [
        "https://github.com/VeeLume/starlume/releases/latest/download/latest.json"
      ]
    },
    "deep-link": {
      "desktop": {
        "schemes": [
          "starlume"
        ]
      }
    }
  }
}

# Copy to .env at the REPO ROOT (gitignored) — `just server-env` does the copy.
# dotenvy resolves .env from the server's working directory upward, so the root
# works no matter where `cargo run -p starlume-server` is invoked from.
# Fill in below. Create the Discord application at
# https://discord.com/developers/applications:
#   New Application → "Starlume" → OAuth2 →
#   add redirect:  http://localhost:5863/auth/discord/callback
#   copy Client ID + reset/copy Client Secret.
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# Where this server is reachable from a browser (Discord redirects here).
# Local dev default; the VPS deployment sets its real https URL — and adds
# the matching redirect to the Discord app (both can coexist).
STARLUME_PUBLIC_URL=http://localhost:5863

# Bind address (default 127.0.0.1:5863) and SQLite location.
# STARLUME_BIND=127.0.0.1:5863
# DATABASE_URL=sqlite://starlume.db
